# RedWing DB Automation — Environment Configuration
# Copy this file to .env and fill in your values.

# Path to the RedWingGCS repository (or a local copy for dev/testing)
REDWING_REPO_PATH=./RedWingGCS

# Excel filename within the repo
EXCEL_FILENAME=Flight_data_updated.xlsx

# Script to regenerate flights.db from Excel
POPULATE_SCRIPT=populate_data.py

# Git branch to push to
GIT_BRANCH=main

# Path to the submissions SQLite database (this backend's own DB)
SUBMISSIONS_DB_PATH=./submissions.db

# Shared secret for webhook authentication
WEBHOOK_SECRET=changeme

# Cesium Ion access token (for 3D waypoint viewer)
CESIUM_ION_TOKEN=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
