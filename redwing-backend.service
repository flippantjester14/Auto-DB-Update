[Unit]
Description=RedWing DB Automation Backend (Uvicorn)
After=network.target

[Service]
User=jester
Group=jester
WorkingDirectory=/home/jester/Auto-DB-Updater/backend
Environment="DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus"

# 10s pre-start delay
ExecStartPre=/bin/sleep 10
ExecStart=/home/jester/Auto-DB-Updater/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
